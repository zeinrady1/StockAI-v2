# ── Required ─────────────────────────────────────────────────────────────────
# Anthropic — get your key at https://console.anthropic.com (~$0.03/analysis run)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Alpaca paper trading — sign up free at https://alpaca.markets
# Dashboard → Paper Trading → API Keys → Generate New Key
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# ── Optional (recommended) ────────────────────────────────────────────────────
# Polygon.io — free tier at https://polygon.io
# Used for: historical daily price bars (technicals) + news with sentiment scores
POLYGON_KEY=your_polygon_api_key_here

# Alpha Vantage — free at https://www.alphavantage.co/support/#api-key
# Used for: fundamentals (P/E, EPS, Beta, revenue growth, analyst targets)
# Note: free tier is 25 API calls/day; the app caches results for 24h
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# ── No key needed ─────────────────────────────────────────────────────────────
# Insider trades:  OpenInsider (SEC Form 4) — scraped, no key
# Congress trades: Capitol Trades — scraped, no key
# Market news:     Google News RSS — no key
# Macro data:      FRED (Federal Reserve) — no key
# Sector data:     NASDAQ Screener — no key
# Crypto prices:   CoinGecko — no key
