{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/dashboard/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|shape|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, shape, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|red|yellow|blue|purple|muted)$/]",
        "message": "<Badge> tone must be one of 'green' | 'red' | 'yellow' | 'blue' | 'purple' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:chip|pill)$/]",
        "message": "<Badge> shape must be one of 'chip' | 'pill'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|full|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, full, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|buy|sell)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'buy' | 'sell'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|inline)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'inline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|accessory|children|bodyStyle|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, accessory, children, bodyStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|wrapStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: icon, wrapStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='IntelRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:ticker|action|meta|onClick|key|ref|className|style|children)$/]",
        "message": "<IntelRow> doesn't accept that prop. Declared props: ticker, action, meta, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|tone|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: label, value, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|red|yellow)$/]",
        "message": "<Stat> tone must be one of 'green' | 'red' | 'yellow'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: id, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='TickerTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:symbol|action|size|onClick|key|ref|className|style|children)$/]",
        "message": "<TickerTag> doesn't accept that prop. Declared props: symbol, action, size, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='TickerTag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<TickerTag> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: checked, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='TradeCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:ticker|action|confidence|price|signals|rationale|onExecute|key|ref|className|style|children)$/]",
        "message": "<TradeCard> doesn't accept that prop. Declared props: ticker, action, confidence, price, signals, rationale, onExecute."
      },
      {
        "selector": "JSXOpeningElement[name.name='TradeCard'] > JSXAttribute[name.name='action'] > Literal[value!=/^(?:buy|sell|hold|watch)$/]",
        "message": "<TradeCard> action must be one of 'buy' | 'sell' | 'hold' | 'watch'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
